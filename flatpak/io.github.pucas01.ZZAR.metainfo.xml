<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.pucas01.ZZAR</id>

  <name>ZZAR</name>
  <summary>Zenless Zone Zero Audio Replacer</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <developer id="io.github.pucas01">
    <name>Pucas01</name>
  </developer>

  <description>
    <p>
      ZZAR is a mod manager and mod creator for Zenless Zone Zero.
      Replace any sound in the game with your own audio. No command line required.
    </p>
    <p>Features:</p>
    <ul>
      <li>Mod Manager: Install, enable/disable, and manage audio mods</li>
      <li>Audio Browser: Browse every sound in the game with preview playback</li>
      <li>Mod Creator: Build your own .zzar mod packages</li>
      <li>Audio Converter: Convert between MP3, WAV, WEM, and other formats automaticly</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.pucas01.ZZAR.desktop</launchable>

  <url type="homepage">https://github.com/Pucas01/ZZAR</url>
  <url type="bugtracker">https://github.com/Pucas01/ZZAR/issues</url>

  <branding>
    <color type="primary" scheme_preference="dark">#1a1a2e</color>
    <color type="primary" scheme_preference="light">#4a90d9</color>
  </branding>

  <content_rating type="oars-1.1" />

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

